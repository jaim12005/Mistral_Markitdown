# .cursorindexingignore
# Controls what gets indexed for semantic search. Inherits .gitignore automatically.
# Files here CAN still be manually @-mentioned. This is about index noise, not security.

# --- Virtual environments (large, low signal) ---
env/
venv/
.venv/

# --- Build and dist output ---
dist/
build/
*.egg-info/

# --- Coverage and test artifacts ---
htmlcov/
.pytest_cache/
__pycache__/
.tox/
.mypy_cache/

# --- Large binary and media assets ---
*.png
*.jpg
*.jpeg
*.gif
*.pdf
*.zip
*.tar.gz
*.whl

# --- Output directories (user content, not code) ---
output_md/
output_txt/
output_images/
cache/
input/

# --- IDE caches ---
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
