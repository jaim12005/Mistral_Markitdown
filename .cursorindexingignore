# .cursorindexingignore
# Controls what gets indexed for semantic search. Inherits .gitignore automatically.
# Files here CAN still be manually @-mentioned or accessed by AI features.
# This is about index noise, not security. Use .cursorignore for secrets.

# --- Dependencies ---
.venv/
venv/
env/
__pypackages__/

# --- Build and dist output ---
dist/
build/
*.egg-info/

# --- Coverage and test artifacts ---
htmlcov/
.pytest_cache/
__pycache__/
.tox/
.mypy_cache/

# --- Large binary and media assets ---
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf
*.zip
*.tar.gz
*.whl

# --- Cache and output directories ---
cache/
output_md/
output_txt/
output_images/
input/
