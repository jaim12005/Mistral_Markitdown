{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bash .cursor/hooks/before-shell-guard.sh",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash .cursor/hooks/after-file-format.sh",
        "timeout": 20
      }
    ],
    "stop": [
      {
        "command": "bash .cursor/hooks/stop-scoped-tests.sh",
        "timeout": 180,
        "loop_limit": 3
      }
    ]
  }
}
