# ============================================================================
# Enhanced Document Converter - Configuration
# ============================================================================
# Copy this file to .env and configure your settings.
# DO NOT commit .env to version control!
#
# Modes:
#   1. Convert (Smart)       - Auto-picks MarkItDown or Mistral OCR per file
#   2. Convert (MarkItDown)  - Force local conversion (no API)
#   3. Convert (Mistral OCR) - Force cloud OCR
#   4. PDF to Images         - Render pages to PNG
#   5. Document QnA          - Ask questions about a document
#   6. Batch OCR             - 50% cost reduction via Mistral Batch API
#   7. System Status         - Cache stats and diagnostics
#   8. Maintenance           - Clear cache, clean up old uploads
# ============================================================================

# ============================================================================
# REQUIRED: Mistral AI API Key
# ============================================================================
# Get your API key from: https://console.mistral.ai/api-keys/
# Without this key, only MarkItDown (local) conversion is available.
MISTRAL_API_KEY="your_mistral_api_key_here"

# ============================================================================
# Mistral OCR Configuration
# ============================================================================

# OCR model (default: mistral-ocr-latest -- the dedicated OCR service)
MISTRAL_OCR_MODEL="mistral-ocr-latest"

# Include extracted images as base64 in OCR output
MISTRAL_INCLUDE_IMAGES="true"

# Save OCR metadata as JSON (needed for quality assessment)
SAVE_MISTRAL_JSON="true"

# Table output format for OCR results
# Options: "" (API default — tables inline in text), "markdown" (proper | table | syntax),
#          "html" (HTML with colspan/rowspan for merged cells)
MISTRAL_TABLE_FORMAT="markdown"

# Extract headers/footers as separate fields (Mistral API defaults to false;
# we default to true for better document structure preservation)
MISTRAL_EXTRACT_HEADER="true"
MISTRAL_EXTRACT_FOOTER="true"

# Image extraction limits (0 = no limit / no minimum)
MISTRAL_IMAGE_LIMIT="0"
MISTRAL_IMAGE_MIN_SIZE="0"

# Maximum file size for Mistral OCR uploads (MB) - files exceeding this are rejected
MISTRAL_OCR_MAX_FILE_SIZE_MB="200"

# Signed URL expiry in hours (increase for large batch jobs)
MISTRAL_SIGNED_URL_EXPIRY="1"

# ============================================================================
# OCR Quality Assessment
# ============================================================================

# Quality score thresholds (0-100 scale)
OCR_QUALITY_THRESHOLD_EXCELLENT="80"
OCR_QUALITY_THRESHOLD_GOOD="60"
OCR_QUALITY_THRESHOLD_ACCEPTABLE="40"

# Enable/disable quality scoring and automatic weak-page reprocessing
ENABLE_OCR_QUALITY_ASSESSMENT="true"
ENABLE_OCR_WEAK_PAGE_IMPROVEMENT="true"

# Fine-tune weak page detection thresholds
OCR_MIN_TEXT_LENGTH="50"
OCR_MIN_UNIQUENESS_RATIO="0.3"
OCR_MAX_PHRASE_REPETITIONS="5"
OCR_MIN_AVG_LINE_LENGTH="10"

# ============================================================================
# Structured Data Extraction (Advanced)
# ============================================================================

# Enable structured output extraction
MISTRAL_ENABLE_STRUCTURED_OUTPUT="true"

# Document schema type for annotation
# Options: invoice, financial_statement, contract, form, generic, auto
MISTRAL_DOCUMENT_SCHEMA_TYPE="auto"

# Enable bounding box / document-level annotation extraction
MISTRAL_ENABLE_BBOX_ANNOTATION="false"
MISTRAL_ENABLE_DOCUMENT_ANNOTATION="false"

# Custom guidance prompt for document annotation LLM
MISTRAL_DOCUMENT_ANNOTATION_PROMPT=""

# ============================================================================
# Image Optimization (pre-OCR)
# ============================================================================

# Resize large images before uploading for OCR
MISTRAL_ENABLE_IMAGE_OPTIMIZATION="true"

# Apply contrast/sharpness enhancement before OCR
MISTRAL_ENABLE_IMAGE_PREPROCESSING="false"

# Maximum image dimension for optimization (pixels)
MISTRAL_MAX_IMAGE_DIMENSION="2048"

# JPEG quality threshold when compressing
MISTRAL_IMAGE_QUALITY_THRESHOLD="70"

# ============================================================================
# Document QnA
# ============================================================================

# Model for natural language document queries
MISTRAL_DOCUMENT_QNA_MODEL="mistral-small-latest"

# Custom system prompt for QnA (empty = no system prompt)
MISTRAL_QNA_SYSTEM_PROMPT=""

# Document image/page limits for QnA (0 = API default: 8 images, 64 pages)
MISTRAL_QNA_DOCUMENT_IMAGE_LIMIT="0"
MISTRAL_QNA_DOCUMENT_PAGE_LIMIT="0"

# Max upload size for Document QnA (MB); align with Mistral limits unless advised otherwise
MISTRAL_QNA_MAX_FILE_SIZE_MB="50"

# When true, QnA document URLs must pass local DNS resolution (fail closed if lookup fails or times out)
MISTRAL_DOCUMENT_URL_STRICT_DNS="false"

# ============================================================================
# Batch OCR (50% cost reduction)
# ============================================================================

# Enable batch OCR processing
MISTRAL_BATCH_ENABLED="true"

# Minimum files to recommend batch mode (informational only)
MISTRAL_BATCH_MIN_FILES="10"

# Fail batch JSONL creation if any file upload fails (default: false = partial batch OK)
MISTRAL_BATCH_STRICT="false"

# Batch job timeout in hours
MISTRAL_BATCH_TIMEOUT_HOURS="24"

# ============================================================================
# Mistral File Upload Management
# ============================================================================

# Automatically clean up old uploaded files
CLEANUP_OLD_UPLOADS="true"

# Delete uploaded files older than N days
UPLOAD_RETENTION_DAYS="7"

# ============================================================================
# MarkItDown Configuration
# ============================================================================

# Enable LLM-powered image descriptions (uses Mistral's OpenAI-compatible endpoint)
MARKITDOWN_ENABLE_LLM_DESCRIPTIONS="false"

# Vision model for image descriptions
MARKITDOWN_LLM_MODEL="pixtral-large-latest"

# Custom prompt for LLM image descriptions (empty = MarkItDown default)
MARKITDOWN_LLM_PROMPT=""

# Enable MarkItDown plugins (needed for audio/video transcription)
MARKITDOWN_ENABLE_PLUGINS="false"

# Enable/disable built-in converters (advanced: set false to selectively re-enable)
MARKITDOWN_ENABLE_BUILTINS="true"

# Preserve base64-encoded images from HTML/DOCX/PPTX in Markdown output
MARKITDOWN_KEEP_DATA_URIS="false"

# DOCX style mapping for mammoth (e.g., "p[style-name='Custom Heading'] => h2:fresh")
MARKITDOWN_STYLE_MAP=""

# Path to ExifTool binary for EXIF metadata extraction
MARKITDOWN_EXIFTOOL_PATH=""

# Maximum file size for processing (MB); files larger than this are rejected
MARKITDOWN_MAX_FILE_SIZE_MB="100"

# ============================================================================
# PDF Table Extraction (pdfplumber + Camelot)
# ============================================================================

# Minimum Camelot accuracy to accept a table (%)
CAMELOT_MIN_ACCURACY="75.0"

# Maximum whitespace percentage to accept (%)
CAMELOT_MAX_WHITESPACE="30.0"

# Camelot stream mode tuning
CAMELOT_STREAM_SPLIT_TEXT="true"
CAMELOT_STREAM_EDGE_TOL="50"
CAMELOT_STREAM_ROW_TOL="2"
CAMELOT_STREAM_COLUMN_TOL="0"

# ============================================================================
# PDF to Image Conversion
# ============================================================================

# Output format: png, jpeg, ppm, tiff
PDF_IMAGE_FORMAT="png"

# Image resolution (DPI)
PDF_IMAGE_DPI="200"

# Concurrent conversion threads
PDF_IMAGE_THREAD_COUNT="4"

# Use pdftocairo for better quality
PDF_IMAGE_USE_PDFTOCAIRO="true"

# ============================================================================
# System Paths (Windows only)
# ============================================================================

# Poppler binaries path (required for PDF to image on Windows)
POPPLER_PATH=""


# ============================================================================
# Performance and Safety
# ============================================================================

# Maximum concurrent files during batch processing
MAX_CONCURRENT_FILES="5"

# Safety guardrails to prevent accidental cost overruns
MAX_BATCH_FILES="100"
MAX_PAGES_PER_SESSION="1000"

# ============================================================================
# Caching
# ============================================================================

# Cache duration in hours (OCR results are cached to avoid redundant API calls)
CACHE_DURATION_HOURS="24"

# Automatically clear expired cache entries on startup
AUTO_CLEAR_CACHE="true"

# ============================================================================
# Mistral HTTP client (SDK)
# ============================================================================

# Per-request HTTP timeout in milliseconds (default 5 minutes for slow OCR).
# Separate from RETRY_MAX_ELAPSED_TIME_MS, which only limits retry backoff.
MISTRAL_CLIENT_TIMEOUT_MS="300000"

# ============================================================================
# Retry Configuration (Mistral API)
# ============================================================================

# Maximum retry attempts for failed API calls
MAX_RETRIES="3"

# Exponential backoff: initial interval (ms), max interval (ms), exponent
RETRY_INITIAL_INTERVAL_MS="1000"
RETRY_MAX_INTERVAL_MS="10000"
RETRY_EXPONENT="2.0"

# Maximum total retry time (ms)
RETRY_MAX_ELAPSED_TIME_MS="60000"

# Retry on connection errors
RETRY_CONNECTION_ERRORS="true"

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Save processing logs to files in logs/
SAVE_PROCESSING_LOGS="true"

# Show progress bars during batch processing
VERBOSE_PROGRESS="true"

# ============================================================================
# Output Configuration
# ============================================================================

# Generate plain text (.txt) alongside Markdown output
GENERATE_TXT_OUTPUT="true"

# Include YAML frontmatter metadata in output files
INCLUDE_METADATA="true"

# Table output formats (comma-separated): markdown, csv
TABLE_OUTPUT_FORMATS="markdown,csv"

# Track batch processing metadata (timing, success/failure per file)
ENABLE_BATCH_METADATA="true"
