[flake8]
# Maximum line length
max-line-length = 120

# Exclude directories
exclude =
    .git,
    __pycache__,
    env,
    venv,
    .venv,
    build,
    dist,
    .eggs,
    *.egg-info,
    tests/fixtures

# Ignore specific error codes
# E203: Whitespace before ':' (conflicts with black)
# W503: Line break before binary operator (conflicts with black)
# E501: Line too long (handled by black)
ignore =
    E203,
    W503,
    E501

# Per-file ignores
# __init__.py: F401 - Imported but unused
# config.py: E402 - Module level import not at top of file (conditional imports)
# main.py: E402 - sys.path setup before local imports
# mistral_converter.py: E402 - sys.path setup before local imports
per-file-ignores =
    __init__.py:F401
    config.py:E402
    main.py:E402,C901
    mistral_converter.py:E402,C901
    tests/test_local_converter.py:E402
    tests/test_mistral_converter.py:E402

# Maximum cyclomatic complexity
max-complexity = 15

# Show source code for each error
show-source = True

# Show statistics
statistics = True

# Count errors
count = True
